{
  "manifest_version": 3,
  "name": "StartSmart",
  "version": "2.0.2",
  "description": "Open your startup URLs by mode and project. Switch between Work and Personal with one click.",
  "permissions": [
    "storage",
    "tabGroups",
    "bookmarks",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StartSmart"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
